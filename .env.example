# ─────────────────────────────────────────────
# Nana App Backend — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# Supabase project URL (from Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service-role key (from Project Settings → API)
# ⚠️  Keep this secret — it bypasses Row Level Security
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase anon/public key (safe to expose to clients)
SUPABASE_ANON_KEY=your-anon-key-here

# The URL of your deployed Vercel frontend (used for CORS)
FRONTEND_URL=https://your-nana-app.vercel.app

# Port to run the Express server on (Railway/Render set this automatically)
PORT=3001
